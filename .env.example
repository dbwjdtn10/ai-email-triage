# LLM API Keys
OPENAI_API_KEY=sk-your-openai-key-here
ANTHROPIC_API_KEY=sk-ant-your-anthropic-key-here

# LangSmith 트레이싱 (https://smith.langchain.com)
LANGCHAIN_TRACING_V2=true
LANGCHAIN_API_KEY=lsv2-your-langsmith-key-here
LANGCHAIN_PROJECT=ai-email-triage

# LLM 설정
PRIMARY_LLM=gpt-4o-mini
FALLBACK_LLM=claude-haiku-4-5-20251001
LLM_TEMPERATURE=0.1
LLM_MAX_RETRIES=2

# 데이터베이스
DATABASE_URL=sqlite:///data/triage.db

# 서버 설정
API_HOST=0.0.0.0
API_PORT=8000

# Rate Limiting
RATE_LIMIT_PROCESS=30/minute
RATE_LIMIT_BATCH=5/minute

# 배치 처리
MAX_CONCURRENT_EMAILS=5

# API 인증 (빈 문자열이면 인증 비활성화)
API_KEY=
